# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files (never commit secrets)
.env*.local
.env
.env.production
.env.development

# local/sensitive data (DB config, user data – use .env + MySQL in production)
docs/VPS_login.md
data/db-config.json
data/db-config.json.backup
data/storage-mode.json
data/work-time.json
data/assigners.json
data/clients.json
data/Untitled

# uploaded avatars (user content – regenerate on deploy)
public/avatars/*
!public/avatars/.gitkeep

# task attachments (user uploads)
public/task-attachments/

# build output
/dist

# deploy archive
timer-afisza-deploy.zip

# PHP vendor (install via composer)
api/vendor/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts


